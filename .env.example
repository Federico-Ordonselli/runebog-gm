# Neon: crea un progetto su neon.tech e copia la connection string (pooled)
DATABASE_URL="postgresql://...@....neon.tech/neondb?sslmode=require"

# Auth.js: genera con
#   node -e 'console.log(require("crypto").randomBytes(32).toString("base64"))'
# NON usare `npx auth secret`: il pacchetto npm "auth" è la CLI di better-auth, non di Auth.js.
AUTH_SECRET=""

# Google OAuth: console.cloud.google.com → Credentials → OAuth client (Web)
# Redirect URI: https://TUODOMINIO/api/auth/callback/google  (e http://localhost:3000/... per dev)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# In produzione su Vercel. Serve anche a costruire i link di recupero password.
AUTH_URL="https://runebog.app"

# Recupero password (Resend). Se queste due restano vuote il sito FUNZIONA lo stesso:
# il link di reset viene stampato nei log del server invece di essere spedito.
# Per spedire davvero serve un dominio verificato su resend.com/domains:
# con onboarding@resend.dev si può scrivere solo alla propria email.
RESEND_API_KEY=""
EMAIL_FROM="Runebog GM <no-reply@send.runebog.app>"
